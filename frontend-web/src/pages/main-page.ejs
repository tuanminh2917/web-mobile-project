<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Main page</title>
    <link rel="stylesheet" href="../assets/main-page.css">
    <link rel="stylesheet" href="../assets/responsive.css">
    <link rel="stylesheet" href="../assets/common.css">
</head>
<body>
    <%- include('components/header') %>
    <main>
        <!-- 1. Carousel nằm trên cùng -->
        <div class="carousel-container">
            <div class="carousel-wrapper">
                <div class="carousel-item"><img src="poster1.jpg" alt="Phim 1"></div>
                <div class="carousel-item"><img src="poster2.jpg" alt="Phim 2"></div>
                <div class="carousel-item"><img src="poster3.jpg" alt="Phim 3"></div>
            </div>
            <button class="prev-btn">&#10094;</button>
            <button class="next-btn">&#10095;</button>
            <div class="dots-container">
                <span class="dot active"></span>
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
        </div>

        <!-- 2. Section Phim đang chiếu -->
        <section class="now-showing">
            <h2>Now Showing</h2>
            <div class="movie-list grid-layout">
                <div class="movie-item">
                    <img src="movie1.jpg" alt="Movie 1">
                    <h3>The Conjuring: Xác Ướp</h3>
                    <p>Khởi chiếu: 17/04/2026</p>
                </div>
                <div class="movie-item">
                    <img src="movie2.jpg" alt="Movie 2">
                    <h3>Movie Title 2</h3>
                    <p>Mô tả ngắn gọn về phim.</p>
                </div>
                <div class="movie-item">
                    <img src="movie3.jpg" alt="Movie 3">
                    <h3>Movie Title 3</h3>
                    <p>Mô tả ngắn gọn về phim.</p>
                </div>
            </div>
        </section>

        <!-- 3. Section Phim sắp chiếu -->
        <section class="coming-soon">
            <h2>Coming Soon</h2>
            <div class="movie-list grid-layout">
                <div class="movie-item">
                    <img src="movie4.jpg" alt="Movie 4">
                    <h3>Movie Title 4</h3>
                    <p>Dự kiến: Tháng 6/2026</p>
                </div>
            </div>
        </section>
    </main>
    <%- include('components/footer') %>
</body>
</html>