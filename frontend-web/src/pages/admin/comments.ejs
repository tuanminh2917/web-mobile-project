<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý bình luận - Admin</title>
  <link rel="stylesheet" href="../../assets/style.css">
  <link rel="stylesheet" href="../../assets/admin.css">
  <link rel="stylesheet" href="../../assets/responsive.css">
  <link rel="stylesheet" href="../../assets/common.css">
</head>
<body>
  <%- include('../../components/header', { currentPage: 'admin' }) %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-brand"><h2><span>A</span>dmin</h2></div>
      <a href="/admin/dashboard" class="nav-item"><span class="icon">&#9632;</span> <span>Dashboard</span></a>
      <a href="/admin/movies" class="nav-item"><span class="icon">&#127910;</span> <span>Quản lý phim</span></a>
      <a href="/admin/screenings" class="nav-item"><span class="icon">&#128197;</span> <span>Quản lý suất chiếu</span></a>
      <a href="/admin/bookings" class="nav-item"><span class="icon">&#128203;</span> <span>Quản lý đặt vé</span></a>
      <a href="/admin/users" class="nav-item"><span class="icon">&#128101;</span> <span>Quản lý người dùng</span></a>
      <a href="/admin/comments" class="nav-item active"><span class="icon">💬</span> <span>Quản lý bình luận</span></a>
      <a href="/admin/advertisements" class="nav-item"><span class="icon">📢</span> <span>Quản lý quảng cáo</span></a>
      <a href="/admin/contact" class="nav-item"><span class="icon">✉️</span> <span>Tin nhắn liên hệ</span></a>
      <a href="/" class="nav-item"><span class="icon">&#8592;</span> <span>Về trang chủ</span></a>
    </aside>

    <div class="admin-content">
      <div class="admin-toolbar">
        <h1>Quản lý bình luận</h1>
        <div class="search-box">
          <input type="text" placeholder="Tìm phim, tác giả..." id="searchInput">
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Phim</th>
            <th>Tác giả</th>
            <th>Nội dung</th>
            <th>Rating</th>
            <th>Ngày</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof comments !== 'undefined' && comments.length) { %>
            <% comments.forEach(c => { %>
              <tr>
                <td><%= c.MovieID %>-<%= c.UserID %></td>
                <td><%= c.MovieTitle %></td>
                <td><%= c.FullName || c.Username %></td>
                <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= c.Content %></td>
                <td><span style="color:var(--accent);">★ <%= c.Rating %>/5</span></td>
                <td><%= new Date(c.CreatedAt).toLocaleDateString('vi-VN') %></td>
                <td>
                  <span class="badge <%= c.IsVisible ? 'active' : 'inactive' %>">
                    <%= c.IsVisible ? 'Hiển thị' : 'Ẩn' %>
                  </span>
                </td>
                <td class="actions">
                  <form action="/admin/comments/<%= c.MovieID %>/<%= c.UserID %>/toggle" method="POST" style="display:inline;">
                    <button type="submit" class="edit-btn"><%= c.IsVisible ? 'Ẩn' : 'Hiển thị' %></button>
                  </form>
                  <form action="/admin/comments/<%= c.MovieID %>/<%= c.UserID %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Xóa bình luận này?')">
                    <button type="submit" class="delete-btn">Xóa</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" style="text-align:center;color:var(--text-muted);">Chưa có bình luận nào</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../../components/footer') %>
  <script src="../../js/main.js"></script>
  <script>
    document.getElementById('searchInput')?.addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.admin-table tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  </script>
</body>
</html>
