<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý suất chiếu - Admin</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/admin.css">
  <link rel="stylesheet" href="/assets/responsive.css">
  <link rel="stylesheet" href="/assets/common.css">
</head>
<body>
  <%- include('../../components/header', { currentPage: 'admin' }) %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-brand"><h2><span>A</span>dmin</h2></div>
      <a href="/admin/dashboard" class="nav-item"><span class="icon">&#9632;</span> <span>Dashboard</span></a>
      <a href="/admin/movies" class="nav-item"><span class="icon">&#127910;</span> <span>Quản lý phim</span></a>
      <a href="/admin/screenings" class="nav-item active"><span class="icon">&#128197;</span> <span>Quản lý suất chiếu</span></a>
      <a href="/admin/bookings" class="nav-item"><span class="icon">&#128203;</span> <span>Quản lý đặt vé</span></a>
      <a href="/admin/users" class="nav-item"><span class="icon">&#128101;</span> <span>Quản lý người dùng</span></a>
      <a href="/admin/comments" class="nav-item"><span class="icon">💬</span> <span>Quản lý bình luận</span></a>
      <a href="/admin/advertisements" class="nav-item"><span class="icon">📢</span> <span>Quản lý quảng cáo</span></a>
      <a href="/admin/contact" class="nav-item"><span class="icon">✉️</span> <span>Tin nhắn liên hệ</span></a>
      <a href="/" class="nav-item"><span class="icon">&#8592;</span> <span>Về trang chủ</span></a>
    </aside>

    <div class="admin-content">
      <div class="admin-toolbar">
        <h1>Quản lý suất chiếu</h1>
        <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='block'">+ Thêm suất chiếu</button>
      </div>

      <% if (typeof adminError !== 'undefined' && adminError) { %>
        <div style="background:#7f1d1d;color:#fca5a5;padding:12px 16px;border-radius:8px;margin-bottom:16px;border:1px solid #ef4444;">
          <%= adminError %>
        </div>
      <% } %>
      <% if (typeof adminSuccess !== 'undefined' && adminSuccess) { %>
        <div style="background:#14532d;color:#86efac;padding:12px 16px;border-radius:8px;margin-bottom:16px;border:1px solid #22c55e;">
          <%= adminSuccess %>
        </div>
      <% } %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Phim</th>
            <th>Phòng</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
            <th>Giá cơ bản</th>
            <th>Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof screenings !== 'undefined' && screenings.length) { %>
            <% screenings.forEach(s => { %>
              <tr>
                <td><%= s.ScreeningID %></td>
                <td><%= s.MovieTitle %></td>
                <td><%= s.RoomName %></td>
                <td><%= new Date(s.StartTime).toLocaleString('vi-VN') %></td>
                <td><%= new Date(s.EndTime).toLocaleString('vi-VN') %></td>
                <td><%= s.BasePrice.toLocaleString() %>đ</td>
                <td class="actions">
                  <button class="edit-btn" onclick="alert('Tính năng sửa đang được cập nhật')">Sửa</button>
                  <form action="/admin/screenings/<%= s.ScreeningID %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa suất chiếu này? (Sẽ xóa luôn vé/hóa đơn liên quan)');">
                    <button type="submit" class="delete-btn">Xóa</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="7" style="text-align:center;color:var(--text-muted);">Chưa có suất chiếu</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add Screening Modal -->
  <div id="addModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:2000;padding:60px 20px;overflow-y:auto;">
    <div style="max-width:500px;margin:0 auto;background:var(--bg-card);padding:30px;border-radius:12px;border:1px solid var(--border-color);">
      <h2 style="color:var(--text-light);margin-bottom:20px;">Thêm suất chiếu</h2>
      <form action="/admin/screenings" method="POST">
        <div style="margin-bottom:16px;">
          <label style="display:block;color:var(--text-muted);font-size:13px;margin-bottom:4px;">Phim</label>
          <select name="movieID" style="width:100%;padding:10px;background:var(--bg-dark);border:1px solid var(--border-color);border-radius:6px;color:var(--text-light);" required>
            <option value="">Chọn phim</option>
            <% if (typeof movies !== 'undefined') { %>
              <% movies.forEach(m => { %>
                <option value="<%= m.MovieID %>"><%= m.Title %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;color:var(--text-muted);font-size:13px;margin-bottom:4px;">Phòng chiếu</label>
          <select name="roomID" style="width:100%;padding:10px;background:var(--bg-dark);border:1px solid var(--border-color);border-radius:6px;color:var(--text-light);" required>
            <option value="">Chọn phòng</option>
            <% if (typeof rooms !== 'undefined') { %>
              <% rooms.forEach(r => { %>
                <option value="<%= r.RoomID %>"><%= r.RoomName %></option>
              <% }); %>
            <% } else { %>
              <option value="1">Phòng Lớn 01</option>
              <option value="2">Phòng Lớn 02</option>
              <option value="3">Phòng Nhỏ 03</option>
              <option value="4">Phòng Nhỏ 04</option>
              <option value="5">Phòng Nhỏ 05</option>
            <% } %>
          </select>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;color:var(--text-muted);font-size:13px;margin-bottom:4px;">Giờ bắt đầu</label>
          <input type="datetime-local" name="startTime" 
            style="width:100%;padding:10px;background:#1e293b;border:1px solid var(--border-color);border-radius:6px;color:#fff;color-scheme:dark;" 
            required>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;color:var(--text-muted);font-size:13px;margin-bottom:4px;">Giá cơ bản</label>
          <input type="number" name="basePrice" value="80000" readonly style="width:100%;padding:10px;background:var(--bg-dark);border:1px solid var(--border-color);border-radius:6px;color:var(--text-light);opacity:0.7;cursor:not-allowed;" required>
        </div>
        <div style="display:flex;gap:12px;justify-content:flex-end;">
          <button type="button" class="btn btn-secondary" onclick="document.getElementById('addModal').style.display='none'">Hủy</button>
          <button type="submit" class="btn btn-primary">Thêm</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../../components/footer') %>
  <script src="../../js/main.js"></script>
  <script>
    // Tự điền giá trị mặc định cho datetime khi mở modal (tránh lỗi AM/PM trống)
    function openAddModal() {
      const modal = document.getElementById('addModal');
      modal.style.display = 'block';

      // Tạo ngày mai 09:00 làm mặc định
      const now = new Date();
      now.setDate(now.getDate() + 1);
      now.setHours(9, 0, 0, 0);

      // Format: YYYY-MM-DDTHH:mm (chuẩn của datetime-local)
      const pad = n => String(n).padStart(2, '0');
      const val = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;
      
      const dtInput = document.getElementById('startTimeInput');
      if (dtInput && !dtInput.value) dtInput.value = val;
    }
  </script>
</body>
</html>
