<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý đặt vé - Admin</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/admin.css">
  <link rel="stylesheet" href="/assets/responsive.css">
  <link rel="stylesheet" href="/assets/common.css">
</head>
<body>
  <%- include('../../components/header', { currentPage: 'admin' }) %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-brand"><h2><span>A</span>dmin</h2></div>
      <a href="/admin/dashboard" class="nav-item"><span class="icon">&#9632;</span> <span>Dashboard</span></a>
      <a href="/admin/movies" class="nav-item"><span class="icon">&#127910;</span> <span>Quản lý phim</span></a>
      <a href="/admin/screenings" class="nav-item"><span class="icon">&#128197;</span> <span>Quản lý suất chiếu</span></a>
      <a href="/admin/bookings" class="nav-item active"><span class="icon">&#128203;</span> <span>Quản lý đặt vé</span></a>
      <a href="/admin/users" class="nav-item"><span class="icon">&#128101;</span> <span>Quản lý người dùng</span></a>
      <a href="/admin/comments" class="nav-item"><span class="icon">💬</span> <span>Quản lý bình luận</span></a>
      <a href="/admin/advertisements" class="nav-item"><span class="icon">📢</span> <span>Quản lý quảng cáo</span></a>
      <a href="/admin/contact" class="nav-item"><span class="icon">✉️</span> <span>Tin nhắn liên hệ</span></a>
      <a href="/" class="nav-item"><span class="icon">&#8592;</span> <span>Về trang chủ</span></a>
    </aside>

    <div class="admin-content">
      <div class="admin-toolbar">
        <h1>Quản lý đặt vé</h1>
        <div class="search-box">
          <input type="text" placeholder="Tìm mã đơn, khách hàng..." id="searchInput">
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Phim</th>
            <th>Suất chiếu</th>
            <th>Ghế</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof bookings !== 'undefined' && bookings.length) { %>
            <% bookings.forEach(b => { %>
              <tr>
                <td>#BK<%= b.BookingID %></td>
                <td><%= b.FullName || b.Username %></td>
                <td><%= b.MovieTitle %></td>
                <td><%= new Date(b.StartTime).toLocaleString('vi-VN') %></td>
                <td><%= b.Seats %></td>
                <td><%= b.TotalPrice.toLocaleString() %>đ</td>
                <td>
                  <span class="badge <%= b.Status === 'Paid' ? 'active' : b.Status === 'Pending' ? 'soon' : 'inactive' %>">
                    <%= b.Status === 'Paid' ? 'Đã thanh toán' : b.Status === 'Pending' ? 'Chờ' : 'Đã hủy' %>
                  </span>
                </td>
                <td class="actions">
                  <button class="view-btn">Chi tiết</button>
                  <% if (b.Status === 'Pending') { %>
                    <button class="edit-btn">Xác nhận</button>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" style="text-align:center;color:var(--text-muted);">Chưa có giao dịch</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../../components/footer') %>
  <script src="../../js/main.js"></script>
  <script>
    document.getElementById('searchInput')?.addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.admin-table tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  </script>
</body>
</html>
