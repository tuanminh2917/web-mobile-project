<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý đặt vé - Admin</title>
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="stylesheet" href="/assets/admin.css">
  <link rel="stylesheet" href="/assets/responsive.css">
  <link rel="stylesheet" href="/assets/common.css">
</head>
<body>
  <%- include('../../components/header', { currentPage: 'admin' }) %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-brand"><h2><span>A</span>dmin</h2></div>
      <a href="/admin/dashboard" class="nav-item"><span class="icon">&#9632;</span> <span>Dashboard</span></a>
      <a href="/admin/movies" class="nav-item"><span class="icon">&#127910;</span> <span>Quản lý phim</span></a>
      <a href="/admin/screenings" class="nav-item"><span class="icon">&#128197;</span> <span>Quản lý suất chiếu</span></a>
      <a href="/admin/bookings" class="nav-item active"><span class="icon">&#128203;</span> <span>Quản lý đặt vé</span></a>
      <a href="/admin/users" class="nav-item"><span class="icon">&#128101;</span> <span>Quản lý người dùng</span></a>
      <a href="/admin/comments" class="nav-item"><span class="icon">💬</span> <span>Quản lý bình luận</span></a>
      <a href="/admin/advertisements" class="nav-item"><span class="icon">📢</span> <span>Quản lý quảng cáo</span></a>
      <a href="/admin/contact" class="nav-item"><span class="icon">✉️</span> <span>Tin nhắn liên hệ</span></a>
      <a href="/" class="nav-item"><span class="icon">&#8592;</span> <span>Về trang chủ</span></a>
    </aside>

    <div class="admin-content">
      <div class="admin-toolbar">
        <h1>Quản lý đặt vé</h1>
        <div class="search-box">
          <input type="text" placeholder="Tìm mã đơn, khách hàng..." id="searchInput">
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Phim</th>
            <th>Suất chiếu</th>
            <th>Ghế</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof bookings !== 'undefined' && bookings.length) { %>
            <% bookings.forEach(b => { %>
              <tr>
                <td>#BK<%= b.BookingID %></td>
                <td><%= b.FullName || b.Username %></td>
                <td><%= b.MovieTitle %></td>
                <td><%= new Date(b.StartTime).toLocaleString('vi-VN') %></td>
                <td><%= b.Seats %></td>
                <td><%= b.TotalPrice.toLocaleString() %>đ</td>
                <td>
                  <span class="badge <%= b.Status === 'Paid' ? 'active' : b.Status === 'Pending' ? 'soon' : 'inactive' %>">
                    <%= b.Status === 'Paid' ? 'Đã thanh toán' : b.Status === 'Pending' ? 'Chờ' : 'Đã hủy' %>
                  </span>
                </td>
                <td class="actions">
                  <button class="view-btn" onclick="showBookingDetail(<%= JSON.stringify(b).replace(/'/g, '&apos;') %>)">Chi tiết</button>
                  <form action="/admin/bookings/<%= b.BookingID %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Xóa đơn đặt vé #BK<%= b.BookingID %>?');">
                    <button type="submit" class="delete-btn">Xóa</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" style="text-align:center;color:var(--text-muted);">Chưa có giao dịch</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../../components/footer') %>
  <script src="/js/main.js"></script>
  <!-- Modal Chi tiết đơn -->
  <div id="bookingDetailModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:2000;padding:60px 20px;overflow-y:auto;">
    <div style="max-width:480px;margin:0 auto;background:var(--bg-card);padding:30px;border-radius:12px;border:1px solid var(--border-color);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2 style="color:var(--text-light);margin:0;">Chi tiết đơn đặt vé</h2>
        <button onclick="document.getElementById('bookingDetailModal').style.display='none'" style="background:none;border:none;color:#9ca3af;font-size:24px;cursor:pointer;">×</button>
      </div>
      <div id="bookingDetailContent" style="display:flex;flex-direction:column;gap:12px;"></div>
    </div>
  </div>
  <script>
    document.getElementById('searchInput')?.addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.admin-table tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });

    function showBookingDetail(b) {
      const rows = [
        ['Mã đơn', '#BK' + b.BookingID],
        ['Khách hàng', b.FullName || b.Username],
        ['Phim', b.MovieTitle],
        ['Phòng chiếu', b.RoomName],
        ['Suất chiếu', new Date(b.StartTime).toLocaleString('vi-VN')],
        ['Ghế', b.Seats],
        ['Tổng tiền', b.TotalPrice.toLocaleString() + 'đ'],
        ['Trạng thái', b.Status === 'Paid' ? 'Đã thanh toán' : b.Status === 'Pending' ? 'Chờ thanh toán' : 'Đã hủy'],
        ['Thời gian đặt', new Date(b.BookingTime).toLocaleString('vi-VN')],
      ];
      document.getElementById('bookingDetailContent').innerHTML = rows.map(([label, value]) =>
        `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-color);">
          <span style="color:var(--text-muted);font-size:14px;">${label}</span>
          <span style="color:var(--text-light);font-size:14px;font-weight:500;">${value}</span>
        </div>`
      ).join('');
      document.getElementById('bookingDetailModal').style.display = 'block';
    }
  </script>
</body>
</html>
