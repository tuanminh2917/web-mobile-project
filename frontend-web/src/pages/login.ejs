<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập - Cinema</title>
  <link rel="stylesheet" href="../assets/style.css">
  <link rel="stylesheet" href="../assets/login.css">
  <link rel="stylesheet" href="../assets/responsive.css">
  <link rel="stylesheet" href="../assets/common.css">
</head>
<body>
  <%- include('../components/header', { currentPage: 'login' }) %>

  <main>
    <div class="login-container">
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="success-message" id="successMsg">
          <p><%= success %></p>
          <button onclick="window.location.href='<%= typeof redirectUrl !== 'undefined' ? redirectUrl : '/' %>'" class="btn btn-primary">Đóng</button>
        </div>
      <% } else { %>
        <h2>Đăng nhập</h2>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error" id="errorMsg">
            <span><%= error %></span>
            <button type="button" onclick="document.getElementById('errorMsg').style.display='none'" class="btn-close">Đóng</button>
          </div>
        <% } %>
        <form action="/login" method="POST">
          <div class="form-row">
            <input type="text" name="username" placeholder="Tên đăng nhập" value="<%= typeof formData !== 'undefined' && formData.username ? formData.username : '' %>" required>
          </div>
          <div class="form-row">
            <input type="password" name="password" placeholder="Mật khẩu" required>
          </div>
          <div class="form-row remember-row">
            <label><input type="checkbox" name="remember"> Ghi nhớ đăng nhập</label>
          </div>
          <div class="btn-container">
            <button type="submit">Đăng nhập</button>
          </div>
        </form>
        <p class="form-footer">Chưa có tài khoản? <a href="/register">Đăng ký ngay</a></p>
      <% } %>
    </div>
  </main>

  <%- include('../components/footer') %>
  <script src="../js/main.js"></script>
</body>
</html>
