<header>
  <a href="/" class="logo" style="text-decoration: none; color: inherit;">
    <img src="/assets/logo.png" alt="Cinema">
    <h1><span>C</span>inema</h1>
  </a>

  <button class="nav-toggle" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>

  <nav class="nav-menu">
    <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Trang chủ</a>
    <a href="/movies" class="<%= currentPage === 'movies' ? 'active' : '' %>">Phim</a>
    <a href="/showtime" class="<%= currentPage === 'showtime' ? 'active' : '' %>">Lịch chiếu</a>
    <a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>">Liên hệ</a>
    <a href="/about" class="<%= currentPage === 'about' ? 'active' : '' %>">Giới thiệu</a>
  </nav>

  <div class="account">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/my-tickets" class="btn btn-sm btn-secondary">Vé của tôi</a>
      <% if (user.Role === 'Admin') { %>
        <a href="/admin/dashboard" class="btn btn-sm btn-accent">Admin</a>
      <% } %>
      <div class="avatar-dropdown">
        <img src="/assets/avatar.png" alt="Avatar" class="avatar" id="avatarBtn">
        <div class="dropdown-menu" id="dropdownMenu">
          <span class="dropdown-user"><%= user.FullName || user.Username %></span>
          <a href="/logout" class="dropdown-item">Đăng xuất</a>
        </div>
      </div>
    <% } else { %>
      <a href="/login" class="btn btn-sm btn-primary">Đăng nhập</a>
      <a href="/register" class="btn btn-sm btn-secondary">Đăng ký</a>
    <% } %>
  </div>
</header>
